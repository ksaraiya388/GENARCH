  "diseases": [
    {
      "id": "dis_asthma",
      "slug": "asthma",
      "name": "Asthma",
      "icd11_code": "CA23",
      "summary": "Asthma is a chronic inflammatory airway disease with variable airflow limitation and episodes of wheeze, cough, and chest tightness. The condition commonly emerges during childhood and adolescence, and symptom severity often changes over time due to environmental exposures and host biology. Atopic pathways, airway epithelial reactivity, and immune cell activation all contribute to phenotype diversity. Population studies indicate a polygenic architecture with many loci of modest effect rather than a single deterministic mutation. In practical terms, asthma risk reflects layered interactions between inherited susceptibility, air quality, household exposures, and developmental timing.",
      "adolescent_relevance": "Adolescence is a key window because lung growth, airway remodeling, and changing outdoor activity patterns can alter exposure burden. Educational prevention strategies in this age range can reduce avoidable exacerbation triggers while reinforcing that GENARCH outputs are population-level and non-clinical.",
      "genetic_architecture": {
        "top_loci": [
          {
            "gene": "il33",
            "variant": "rs992969",
