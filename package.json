{
  "name": "genarch",
  "version": "1.0.0",
  "private": true,
  "description": "GENARCH — Global Exposome & Genetic Epidemiology Atlas",
  "scripts": {
    "site:dev": "npm run dev --prefix site",
    "site:build": "npm run build --prefix site",
    "site:lint": "npm run lint --prefix site",
    "pipeline:update": "python -m pipeline.update --scope all",
    "pipeline:validate": "python -m pipeline.validate",
    "pipeline:report": "python -m pipeline.report --year 2026"
  },
